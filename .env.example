# SmugMug API
SMUGMUG_API_KEY=
SMUGMUG_API_SECRET=
SMUGMUG_ACCESS_TOKEN=
SMUGMUG_ACCESS_TOKEN_SECRET=
SMUGMUG_NICKNAME=
SMUGMUG_BASE_URL=https://pixilens.com

# Database
DATABASE_URL=
DATABASE_SCHEMA=pixilens_smugmug
POSTGRES_SSLMODE=require
SSL_CERTS_DIR=/app/certs

# Media storage
MEDIA_ROOT=/mnt/pixilens-media/media

# Admin/auth
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=
SESSION_SECRET=
ADMIN_DATA_DIR=/app/data/admin

# Microsoft Graph Mail.Send for public enquiry forms
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_SENDER=contact@pixilens.com

# Public site URL (canonical, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://pixilens.com

# Google Analytics 4 (replaces SmugMug UA-93000127-1)
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console HTML meta verification (content value only)
GOOGLE_SITE_VERIFICATION=

# Set false on private staging
# ALLOW_SEARCH_INDEXING=false
